{
  "name": "autoflex-vue",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:dev": "start-server-and-test dev http://localhost:5173 cy:open",
    "cy:ci": "start-server-and-test dev http://localhost:5173 cy:run"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "pinia": "^3.0.3",
    "primeicons": "^7.0.0",
    "primevue": "^3.53.1",
    "vue": "^3.5.22",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^24.5.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "cypress": "^15.11.0",
    "jsdom": "^28.1.0",
    "start-server-and-test": "^2.1.5",
    "type-fest": "^3.13.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.1.0"
  }
}